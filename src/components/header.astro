---
import ThemeSwitcher from "~/components/theme-switcher.astro";
import { Icon } from "astro-icon/components";
---
<header
  id="page-header"
  class="fixed top-0 z-50 flex w-full items-center justify-between border-b border-transparent px-8 py-4 transition-all duration-300"
>
  <a href="/" class="logo-font text-2xl font-bold hover:opacity-80 transition-opacity">
    <span class="gradient-text">GAme</span>TIPSY
  </a>

  <div class="flex items-center gap-6">
    <nav class="hidden sm:block">
      <ul class="flex items-center gap-6 text-sm">
        <li><a href="#featured" class="hover:text-secondary transition-colors">Artikel</a></li>
        <li><a href="#kenapa" class="hover:text-secondary transition-colors">Kenapa?</a></li>
        <li><a href="#kategori" class="hover:text-secondary transition-colors">Kategori</a></li>
      </ul>
    </nav>
    <button id="open-nav-button" type="button" class="sm:hidden" aria-label="Navigation">
      <Icon name="mdi:menu" class="size-6" />
    </button>
    <ThemeSwitcher />
  </div>

  <!-- Mobile menu -->
  <div id="menu-modal" class="hidden fixed inset-0 z-50 bg-default px-8 py-6" aria-hidden="true">
    <div role="dialog" aria-modal="true">
      <div class="flex justify-between items-center mb-8">
        <span class="logo-font text-2xl font-bold">
          <span class="gradient-text">GAme</span>TIPSY
        </span>
        <button id="close-nav-button" type="button" aria-label="Close navigation">
          <Icon name="mdi:close" class="size-6" />
        </button>
      </div>
      <nav>
        <ul class="flex flex-col gap-6 text-xl font-semibold">
          <li><a href="#featured">Artikel</a></li>
          <li><a href="#kenapa">Kenapa?</a></li>
          <li><a href="#kategori">Kategori</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector("#page-header") as HTMLElement;
  const menuModal = document.querySelector("#menu-modal") as HTMLElement;
  const openBtn = document.querySelector("#open-nav-button");
  const closeBtn = document.querySelector("#close-nav-button");

  openBtn?.addEventListener("click", () => {
    menuModal.classList.remove("hidden");
    menuModal.setAttribute("aria-hidden", "false");
  });
  closeBtn?.addEventListener("click", () => {
    menuModal.classList.add("hidden");
    menuModal.setAttribute("aria-hidden", "true");
  });
  menuModal.querySelectorAll("a").forEach(a => {
    a.addEventListener("click", () => {
      menuModal.classList.add("hidden");
      menuModal.setAttribute("aria-hidden", "true");
    });
  });

  document.addEventListener("scroll", () => {
    header.classList.toggle("scrolled-header", window.scrollY > 10);
  });
</script>

<style>
  .scrolled-header {
    border-color: var(--color-border);
    background-color: var(--color-background);
    backdrop-filter: blur(8px);
  }
</style>
