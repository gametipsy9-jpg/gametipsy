---
import Header from "~/components/header.astro";
import Footer from "~/components/footer.astro";
import { getCollection } from "astro:content";
import "~/styles/index.css";

const allPosts = await getCollection("blog");
const randomFinds = allPosts.filter(p => p.data.category === "Random Finds");
const hiddenGems = allPosts.filter(p => p.data.category === "Hidden Gems");
---
<!doctype html>
<html lang="id" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <title>Sitemap — Gametipsy</title>
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      }
    </script>
  </head>
  <body class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white font-sans">
    <Header />
    <section class="max-w-2xl mx-auto px-8 pt-36 pb-20">
      <a href="/" class="text-sm text-offset hover:text-secondary transition-colors">← Kembali</a>
      <h1 class="text-4xl font-bold mt-6 mb-12 font-heading">Sitemap</h1>

      <!-- Halaman Utama -->
      <div class="mb-12">
        <h2 class="text-xs uppercase tracking-wide text-offset mb-4">Halaman</h2>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="hover:text-secondary transition-colors">Home</a></li>
          <li><a href="/about" class="hover:text-secondary transition-colors">About</a></li>
          <li><a href="/contact" class="hover:text-secondary transition-colors">Contact</a></li>
          <li><a href="/privacy" class="hover:text-secondary transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-secondary transition-colors">Terms</a></li>
        </ul>
      </div>

      <!-- Kategori -->
      <div class="mb-12">
        <h2 class="text-xs uppercase tracking-wide text-offset mb-4">Kategori</h2>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="/kategori/random-finds" class="hover:text-secondary transition-colors">
              🎲 Random Finds
            </a>
            <span class="text-offset text-xs ml-2">({randomFinds.length} artikel)</span>
          </li>
          <li>
            <a href="/kategori/hidden-gems" class="hover:text-secondary transition-colors">
              💎 Hidden Gems
            </a>
            <span class="text-offset text-xs ml-2">({hiddenGems.length} artikel)</span>
          </li>
        </ul>
      </div>

    </section>
    <Footer />
  </body>
</html>
