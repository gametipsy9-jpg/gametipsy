---
import Header from "~/components/header.astro";
import Footer from "~/components/footer.astro";
import { getCollection } from "astro:content";
import "~/styles/index.css";
const { generator, site } = Astro;
const description = "Buat lo yang udah bosan sama game AAA, di sini lo bakal nemuin game random yang jarang dilirik tapi surprisingly worth it.";
const allPosts = await getCollection("blog");
const latestPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---
<!doctype html>
<html lang="id" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta name="generator" content={generator} />
    <title>Gametipsy — Game aneh, tapi bikin nagih</title>
    <meta name="description" content={description} />
    <meta property="og:title" content="Gametipsy" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      }
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (event) => {
        if (!localStorage.getItem("theme")) {
          document.documentElement.dataset.theme = event.matches ? "dark" : "light";
        }
      });
    </script>
  </head>
  <body class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white font-sans">
    <Header />

    <!-- HERO -->
    <section class="flex min-h-screen flex-col items-center justify-center px-8 text-center pt-24 pb-16">
      <h1 class="text-6xl sm:text-8xl font-bold mb-6 font-heading">
        <span class="gradient-text">Game</span>tipsy
      </h1>
      <p class="max-w-xl text-lg sm:text-xl text-offset leading-relaxed mb-10">
        Buat lo yang udah <span class="gradient-text font-semibold">bosan sama game AAA</span>, di sini lo bakal nemuin <span class="gradient-text font-semibold">game random yang jarang dilirik</span> tapi surprisingly worth it.
      </p>
      <div class="flex justify-center">
        <a href="#featured" class="btn-primary px-8 py-3 rounded-full text-sm font-semibold">
          Lihat Artikel
        </a>
      </div>
    </section>

    <!-- FEATURED -->
    <section id="featured" class="px-8 py-20 max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold mb-10 font-heading">Artikel Terbaru</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {latestPosts.length === 0 ? (
          <div class="group rounded-2xl overflow-hidden border border-default bg-offset">
            <div class="aspect-video bg-gradient-to-br from-indigo-900 to-pink-900 flex items-center justify-center text-4xl">
              🎮
            </div>
            <div class="p-5">
              <span class="text-xs text-secondary uppercase tracking-wide">Random Finds</span>
              <h3 class="mt-2 font-semibold text-base group-hover:text-secondary transition-colors">
                Artikel akan muncul di sini
              </h3>
              <p class="text-offset text-sm mt-2 line-clamp-2">
                Tulis artikel pertamamu lewat Pages CMS dan akan otomatis muncul di sini.
              </p>
            </div>
          </div>
        ) : (
          latestPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group rounded-2xl overflow-hidden border border-default bg-offset hover:border-secondary transition-colors">
              {post.data.thumbnail ? (
                <img src={post.data.thumbnail} alt={post.data.title} class="aspect-video w-full object-cover" />
              ) : (
                <div class="aspect-video bg-gradient-to-br from-indigo-900 to-pink-900 flex items-center justify-center text-4xl">
                  🎮
                </div>
              )}
              <div class="p-5">
                <span class="text-xs text-secondary uppercase tracking-wide">{post.data.category}</span>
                <h3 class="mt-2 font-semibold text-base group-hover:text-secondary transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-offset text-sm mt-2 line-clamp-2">
                  {post.data.excerpt}
                </p>
              </div>
            </a>
          ))
        )}
      </div>
    </section>

    <!-- TENTANG GAMETIPSY -->
    <section id="tentang" class="px-8 py-20 bg-offset">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl font-bold mb-12 font-heading">Tentang Gametipsy</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {[
            { icon: "🕹️", title: "Game Obscure", desc: "Gametipsy ngumpulin game-game yang jarang dilirik tapi sebenarnya worth it untuk dimainkan." },
            { icon: "🤓", title: "Dari Gamer", desc: "Gametipsy dibuat oleh gamer yang kebetulan juga suka deep browsing & blogging." },
            { icon: "🎯", title: "To the Point", desc: "Ga kayak blog gaming lain yang bertele-tele, di sini Lo bakal langsung tahu kalau game ini itu seru untuk dimainkan." },
          ].map(({ icon, title, desc }) => (
            <div class="flex flex-col items-center gap-3">
              <span class="text-4xl">{icon}</span>
              <h3 class="font-semibold text-base">{title}</h3>
              <p class="text-offset text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- KATEGORI -->
    <section id="kategori" class="px-8 py-20 max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold mb-10 font-heading">KATEGORI</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { emoji: "🎲", title: "Random Finds", slug: "random-finds", desc: "Game yang ditemukan secara random, dicoba, dan ternyata seru." },
          { emoji: "💎", title: "Hidden Gems", slug: "hidden-gems", desc: "Game yang seharusnya lebih terkenal dari sekarang. Underrated, underplayed, tapi undeniably bagus." },
        ].map(({ emoji, title, slug, desc }) => (
          <a href={`/kategori/${slug}`} class="rounded-2xl border border-default p-8 flex gap-5 hover:border-secondary transition-colors">
            <span class="text-5xl">{emoji}</span>
            <div>
              <h3 class="font-bold text-lg mb-2">{title}</h3>
              <p class="text-offset text-sm leading-relaxed">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </body>
</html>
