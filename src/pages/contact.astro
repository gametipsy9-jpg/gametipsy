---
import Header from "~/components/header.astro";
import Footer from "~/components/footer.astro";
import "~/styles/index.css";
---
<!doctype html>
<html lang="id" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <title>Contact — Gametipsy</title>
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      document.documentElement.dataset.theme = themeSaved ?? "dark";
    </script>
  </head>
  <body class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white font-sans">
    <Header />
    <section class="max-w-2xl mx-auto px-8 pt-36 pb-20">
      <a href="/" class="text-sm text-offset hover:text-secondary transition-colors">← Kembali</a>
      <h1 class="text-4xl font-bold mt-6 mb-8 font-heading">Contact</h1>
      <p class="text-offset leading-relaxed mb-8">Ada pertanyaan, saran, atau mau kolaborasi? Hubungi lewat Twitter/X.</p>
      
      <a href="https://twitter.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border border-default px-6 py-3 rounded-full text-sm hover:border-secondary transition-colors"
      >
        Twitter/X Gametipsy
      </a>
    </section>
    <Footer />
  </body>
</html>
