---
import Header from "~/components/header.astro";
import Footer from "~/components/footer.astro";
import { getCollection } from "astro:content";
import "~/styles/index.css";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((post) => post.data.category === "Hidden Gems")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<!doctype html>
<html lang="id" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <title>Hidden Gems — Gametipsy</title>
    <meta name="description" content="Game yang seharusnya lebih terkenal dari sekarang. Underrated, underplayed, tapi undeniably bagus." />
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      document.documentElement.dataset.theme = themeSaved ?? "dark";
    </script>
  </head>
  <body class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white font-sans">
    <Header />
    <section class="max-w-6xl mx-auto px-8 pt-36 pb-20">
      <div class="mb-12">
        <a href="/" class="text-sm text-offset hover:text-secondary transition-colors">← Kembali</a>
        <h1 class="text-4xl sm:text-5xl font-bold mt-6 mb-4 font-heading">
          💎 Hidden Gems
        </h1>
        <p class="text-offset text-lg">Game yang seharusnya lebih terkenal dari sekarang. Underrated, underplayed, tapi undeniably bagus.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {posts.length === 0 ? (
          <div class="group rounded-2xl overflow-hidden border border-default bg-offset">
            <div class="aspect-video bg-gradient-to-br from-indigo-900 to-pink-900 flex items-center justify-center text-4xl">
              🎮
            </div>
            <div class="p-5">
              <span class="text-xs text-secondary uppercase tracking-wide">Hidden Gems</span>
              <h3 class="mt-2 font-semibold text-base group-hover:text-secondary transition-colors">
                Artikel akan muncul di sini
              </h3>
              <p class="text-offset text-sm mt-2 line-clamp-2">
                Tulis artikel pertamamu lewat Pages CMS dan akan otomatis muncul di sini.
              </p>
            </div>
          </div>
        ) : (
          posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group rounded-2xl overflow-hidden border border-default bg-offset hover:border-secondary transition-colors">
              {post.data.thumbnail ? (
                <img src={post.data.thumbnail} alt={post.data.title} class="aspect-video w-full object-cover" />
              ) : (
                <div class="aspect-video bg-gradient-to-br from-indigo-900 to-pink-900 flex items-center justify-center text-4xl">
                  🎮
                </div>
              )}
              <div class="p-5">
                <span class="text-xs text-secondary uppercase tracking-wide">{post.data.category}</span>
                <h3 class="mt-2 font-semibold text-base group-hover:text-secondary transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-offset text-sm mt-2 line-clamp-2">
                  {post.data.excerpt}
                </p>
              </div>
            </a>
          ))
        )}
      </div>
    </section>
    <Footer />
  </body>
</html>
